                            <span class="badge-user">USER</span>
                        <?php } ?>
                    </td>
                    <td><?= $stats[$user->getId()]['total'] ?></td>
                    <td>👁️ <?= $stats[$user->getId()]['watched'] ?></td>
                    <td>🕒 <?= $stats[$user->getId()]['towatch'] ?></td>
                    <td><?= $user->getCreatedAt() ?></td>
                    <td class="admin-actions">
