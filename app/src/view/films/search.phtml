<?php $title = "Recherche TMDB"; ?>

<?php ob_start() ?>

<div class="search-container">

    <div class="search-input-row">
        <input type="text" id="search-input" class="search-input"
            placeholder="Rechercher un film..."
            value="<?= htmlspecialchars($_GET['query'] ?? '') ?>"
            autocomplete="off">
    </div>

    <div id="search-loader" class="search-loader" style="display:none;">🔍 Recherche en cours...</div>
    <div id="search-results" class="search-grid"></div>
    <p id="search-empty" class="empty-message" style="display:none;">🎬 Aucun résultat trouvé.</p>

</div>

<script>
const input = document.getElementById('search-input');
const resultsContainer = document.getElementById('search-results');
const loader = document.getElementById('search-loader');
const emptyMessage = document.getElementById('search-empty');
const imageBaseUrl = '<?= TMDB_IMAGE_URL ?>';

let debounceTimer;

input.addEventListener('input', function () {
    const query = this.value.trim();

    // Réinitialise le timer à chaque frappe
    clearTimeout(debounceTimer);

    // Vide les résultats si la recherche est trop courte
    if (query.length < 2) {
        resultsContainer.innerHTML = '';
        emptyMessage.style.display = 'none';
        loader.style.display = 'none';
        return;
    }

    // Attend 400ms après la dernière frappe avant d'envoyer la requête
    debounceTimer = setTimeout(() => {
        searchFilms(query);
    }, 400);
});

async function searchFilms(query) {
    loader.style.display = 'block';
    resultsContainer.innerHTML = '';
    emptyMessage.style.display = 'none';

    try {
        const response = await fetch(`?route=searchApi&query=${encodeURIComponent(query)}`);
        const films = await response.json();

        loader.style.display = 'none';

        if (films.length === 0) {
            emptyMessage.style.display = 'block';
            emptyMessage.textContent = `🎬 Aucun résultat pour "${query}"`;
            return;
        }

        resultsContainer.innerHTML = films.map(film => `
            <a href="?route=showTmdb&id=${film.id}" class="card-link">
                <div class="card">
                    ${film.poster_path
                        ? `<img src="${imageBaseUrl}${film.poster_path}" alt="${escapeHtml(film.title)}">`
                        : `<div class="no-poster">🎥</div>`
                    }
                    <div class="search-title">${escapeHtml(film.title)}</div>
                    <div class="search-meta">📅 ${film.release_date ? film.release_date.substring(0, 4) : 'n/c'}</div>
                </div>
            </a>
        `).join('');

    } catch (error) {
        loader.style.display = 'none';
        emptyMessage.style.display = 'block';
        emptyMessage.textContent = '❌ Erreur lors de la recherche.';
    }
}

// Fonction pour éviter les injections XSS dans le JS
function escapeHtml(str) {
    const div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
}

// Lance la recherche si une valeur est déjà présente (retour arrière)
if (input.value.trim().length >= 2) {
    searchFilms(input.value.trim());
}
</script>

<?php $content = ob_get_clean() ?>
